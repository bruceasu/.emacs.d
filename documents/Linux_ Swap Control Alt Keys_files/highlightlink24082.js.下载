const currentPath = window.location.pathname;
if ( currentPath.length >= 5 && (currentPath !== "/index.html")) {
const allLinks = document.querySelectorAll ( 'a' );
for (let i = 0; i < allLinks.length; i++) {
    const thisLink = allLinks [i];
    if ( thisLink.href.includes(currentPath) ) {
        const pNode = thisLink.parentElement;
        const pName = pNode.nodeName;
        if ( pName === "LI" ) {
            pNode.style.backgroundColor = "lime";
        }
        else {
            thisLink.style.backgroundColor = "lime"; }
    };
}
}
