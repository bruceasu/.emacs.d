;;; he.el --- Emacs port of he Chinese input method  -*-coding: utf-8;-*-
;;; To activate the input method, type C-u C-\ math RET
(provide 'he-quick)
(setq default-input-method "chinese-he")
(quail-define-package
 "chinese-he" "Chinese" "快手" t "he-quick"
 '((" " . quail-select-current)
   (">" . quail-next-translation-block)
   ("<" . quail-prev-translation-block)
   ("\C-n" . quail-next-translation-block)
   ("\C-p" . quail-prev-translation-block)
   ("\C-f" . quail-next-translation)
   ("\C-b" . quail-prev-translation)
   ) t nil nil nil nil nil nil nil nil t)

